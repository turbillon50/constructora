# ============================================================================
# CASTORES - ENV TEMPLATE FOR VERCEL DEMO
# ============================================================================
# Nunca subas secretos reales. Usa solo placeholders en este archivo.

# ─── Base de datos (API) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# ─── Sesion servidor (API) ──────────────────────────────────────────────────
# Genera un valor largo y aleatorio para production.
SESSION_SECRET=replace_with_long_random_secret

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
# Server (API):
CLERK_SECRET_KEY=sk_test_replace_me
# Frase segura para activar administrador general inicial (solo server-side):
ADMIN_ACCESS_PHRASE=CASTORES
# Client (Web Vite):
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Opcional si usas proxy de Clerk en el mismo dominio:
VITE_CLERK_PROXY_URL=

# ─── API runtime ─────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── Web runtime (Vite) ──────────────────────────────────────────────────────
# En produccion suele ser "/" si se publica en raiz.
BASE_PATH=/
# Opcional para deploy en dos proyectos Vercel (web + api).
# Ejemplo: https://castores-api.vercel.app
VITE_API_BASE_URL=

# ─── Invitaciones / redirecciones ────────────────────────────────────────────
# URL publica del frontend, sin slash final. Ejemplo:
# https://demo-castores.vercel.app
FRONTEND_PUBLIC_URL=

# ─── CORS adicional (opcional) ───────────────────────────────────────────────
# Lista separada por coma de origenes adicionales permitidos por la API.
# FRONTEND_PUBLIC_URL ya se considera permitido automaticamente.
# Ejemplo: https://staging-castores.vercel.app,https://www.castores.info
ALLOWED_ORIGINS=

# ─── Email transaccional (opcional para demo) ───────────────────────────────
RESEND_API_KEY=
